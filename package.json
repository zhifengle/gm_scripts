{
  "name": "gm_script",
  "version": "0.0.1",
  "description": "gm scripts",
  "main": "src/index.js",
  "scripts": {
    "build": "pnpm run build:export_tool && pnpm run build:douban && pnpm run build:anime_score && pnpm run build:score_helper && pnpm run build:qiandao && pnpm run build:skip_intro && pnpm run build:infobox_fold && pnpm run build:reply-extractor",
    "build:export_tool": "cross-env SCRIPT_NAME=bangumi_collection_export_tool rollup -c build/rollup.config.us.mjs",
    "build:douban": "cross-env SCRIPT_NAME=migrate_douban_collection_to_bangumi rollup -c build/rollup.config.us.mjs",
    "build:anime_score": "cross-env SCRIPT_NAME=bangumi_anime_score_compare rollup -c build/rollup.config.us.mjs",
    "build:score_helper": "cross-env SCRIPT_NAME=score_comparation_helper rollup -c build/rollup.config.us.mjs",
    "build:qiandao": "cross-env SCRIPT_NAME=qiandao XHR_MODE=fetch rollup -c build/rollup.config.us.mjs",
    "build:skip_intro": "cross-env SCRIPT_NAME=skip_intro rollup -c build/rollup.config.us.mjs",
    "build:infobox_fold": "cross-env SCRIPT_NAME=bangumi_infobox_fold rollup -c build/rollup.config.us.mjs",
    "build:reply-extractor": "cross-env SCRIPT_NAME=reply-extractor rollup -c build/rollup.config.us.mjs",
    "dev:douban": "cross-env SCRIPT_NAME=migrate_douban_collection_to_bangumi rollup -w -c build/rollup.config.us.mjs",
    "dev:anime_score": "cross-env SCRIPT_NAME=bangumi_anime_score_compare rollup -w -c build/rollup.config.us.mjs",
    "dev:score_helper": "cross-env SCRIPT_NAME=score_comparation_helper rollup -w -c build/rollup.config.us.mjs",
    "dev:test": "rollup -w -c build/rollup.config.dev.mjs",
    "dev:user_script": "cross-env SCRIPT_NAME=dev rollup -w -c build/rollup.config.us.dev.mjs",
    "clean": "rimraf dist/",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:test",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "author": "22earth",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@types/node": "^24.10.2",
    "cross-env": "10.1.0",
    "fuse.js": "6.4.0",
    "rimraf": "6.1.3",
    "rollup": "4.60.1",
    "rollup-plugin-typescript2": "0.37.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.0",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "dependencies": {
    "bangumi-data": "0.3.99",
    "kv-expiration": "0.0.6",
    "tiny-segmenter": "0.2.0"
  }
}
